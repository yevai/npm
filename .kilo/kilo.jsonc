{
  "$schema": "https://app.kilo.ai/config.json",
  "mcp": {
    "tavily": {
      "type": "local",
      "command": ["npx", "-y", "tavily-mcp@0.2.3"],
      "environment": {
        "TAVILY_API_KEY": "{env:TAVILY_API_KEY}",
      },
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "environment": {
        "DEFAULT_MINIMUM_TOKENS": "{{DEFAULT_MINIMUM_TOKENS}}",
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
    },
  },
  "indexing": {
    "enabled": true,
    "provider": "openrouter",
    "model": "google/gemini-embedding-001",
    "dimension": 3072,
    "openrouter": {
      "specificProvider": "google-ai-studio",
      // provide "apiKey" for this to work.
    },
    "vectorStore": "qdrant",
    "qdrant": {
      "url": "http://localhost:6333",
    },
    "searchMaxResults": 12,
    "searchMinScore": 0.59,
    "embeddingBatchSize": 60,
  },
  "experimental": {
    "batch_tool": true,
    "openTelemetry": true,
  },
  "permission": {
    "bash": {
      "git status": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "ls*": "allow",
      "wc*": "allow",
      "*": "ask",
    },
    "tavily_*": "allow",
    "grep": "allow",
    "glob": "allow",
    "read": "allow",
    "semantic_search": "allow",
    "websearch": "deny",
    "webfetch": "deny",
    "todoread": "allow",
    "todowrite": "allow",
    "skill": "allow",
    "task": "allow",
    "list": "allow",
    "lsp": "allow",
  },
  "default_agent": "code",
  "agent": {
    "general": {
      "model": "openrouter/z-ai/glm-5.2",
    },
    "explore": {
      "model": "openrouter/moonshotai/kimi-k2.7-code",
    },
    "summary": {
      "model": "google/gemini-3.5-flash",
    },
    "plan": {
      "model": "anthropic/claude-sonnet-5",
    },
  },
  "model": "openrouter/moonshotai/kimi-k2.7-code",
  "subagent_model": "openrouter/z-ai/glm-5.2",
  "small_model": "openrouter/z-ai/glm-5.2",
  "provider": {
    "openrouter": {
      "models": {
        "z-ai/glm-5.2": {
          "limit": {
            "context": 1048576,
            "input": 0,
            "output": 32768,
          },
          "options": {
            "provider": {
              "only": ["parasail/fp4"],
              "allow_fallbacks": false,
            },
          },
        },
        "moonshotai/kimi-k2.7-code": {
          "limit": {
            "context": 262144,
            "input": 0,
            "output": 16384,
          },
          "options": {
            "provider": {
              "only": ["together"],
              "allow_fallbacks": false,
            },
          },
        },
        "google/gemini-3.5-flash": {
          "limit": {
            "context": 1048576,
            "input": 0,
            "output": 65536,
          },
          "options": {
            "provider": {
              "only": ["google-ai-studio"],
              "allow_fallbacks": false,
            },
          },
        },
      },
    },
    "google-ai-studio": {
      "models": {
        "gemini-3.5-flash": {
          "limit": {
            "context": 1048576,
            "input": 0,
            "output": 65536,
          },
        },
      },
    },
    "anthropic": {
      "models": {
        "claude-fable-5": {
          "limit": {
            "context": 1000000,
            "input": 0,
            "output": 128000,
          },
        },
        "claude-sonnet-5": {
          "limit": {
            "context": 1000000,
            "input": 0,
            "output": 128000,
          },
        },
      },
    },
  },
}
