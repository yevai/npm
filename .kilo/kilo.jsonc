{
  // Default Kilo Code schema is outdated and incomplete
  "$schema": "./kilo-schema.json",
  "mcp": {
    "tavily": {
      "type": "local",
      "command": ["npx", "-y", "tavily-mcp@0.2.3"],
      "environment": {
        "TAVILY_API_KEY": "{env:TAVILY_API_KEY}",
      },
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "environment": {
        "DEFAULT_MINIMUM_TOKENS": "{{DEFAULT_MINIMUM_TOKENS}}",
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
    },
  },
  "indexing": {
    "enabled": true,
    "provider": "openrouter",
    "model": "google/gemini-embedding-001",
    "dimension": 3072,
    "openrouter": {
      "specificProvider": "google-ai-studio",
    },
    "vectorStore": "qdrant",
    "qdrant": {
      "url": "http://localhost:6333",
    },
    "searchMaxResults": 12,
    "searchMinScore": 0.59,
    "embeddingBatchSize": 60,
  },
  "experimental": {
    "batch_tool": true,
    "openTelemetry": true,
  },
  "permission": {
    "bash": {
      "git status": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "ls*": "allow",
      "wc*": "allow",
      "*": "ask",
    },
    "tavily_*": "allow",
    "grep": "allow",
    "glob": "allow",
    "read": "allow",
    "semantic_search": "allow",
    "websearch": "deny",
    "webfetch": "deny",
    "todoread": "allow",
    "todowrite": "allow",
    "skill": "allow",
    "task": "allow",
    "list": "allow",
    "lsp": "allow",
  },
  "default_agent": "ask",
  "model": "openrouter/x-ai/grok-4.5", // This is the default model if none is defined.
  "agent": {
    "ask": {
      "model": "openrouter/moonshotai/kimi-k2.7-code",
      "variant": "thinking",
    },
    "general": {
      "model": "openrouter/x-ai/grok-4.5",
    },
    "explore": {
      "model": "zai-coding-plan/glm-5.2",
      "variant": "high",
    },
    "debug": {
      "model": "openrouter/google/gemini-3.5-flash",
      "variant": "high",
    },
    "plan": {
      "model": "anthropic/claude-fable-5",
      "variant": "low",
    },
    "build": {
      "model": "openrouter/moonshotai/kimi-k2.7-code",
    },
    "code": {
      "model": "openrouter/x-ai/grok-4.5",
    },
  },
  "subagent_model": "zai-coding-plan/glm-5.2", // Slow but extremely effective economically.
  "subagent_variant_overrides": {
    "zai-coding-plan/glm-5.2": "high",
  },
  "small_model": "openrouter/moonshotai/kimi-k2.7-code",
  "provider": {
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}",
      },
      "models": {
        "x-ai/grok-4.5": {
          "limit": {
            "context": 524288,
            "input": 0,
            "output": 524288,
          },
          "options": {
            "provider": {
              "only": ["xai/zdr"],
              "allow_fallbacks": false,
            },
          },
        },
        "z-ai/glm-5.2": {
          "limit": {
            "context": 1048576,
            "input": 0,
            "output": 131072,
          },
          "options": {
            "provider": {
              "max_price": {
                "prompt": "1.5",
                "completion": "5",
              },
              "sort": "throughput",
              "allow_fallbacks": true,
            },
          },
        },
        "moonshotai/kimi-k2.7-code": {
          "limit": {
            "context": 262144,
            "input": 0,
            "output": 16384,
          },
          "options": {
            "provider": {
              "max_price": {
                "prompt": "1",
                "completion": "4.1",
              },
              "sort": "throughput",
              "allow_fallbacks": true,
            },
          },
        },
        "deepseek/deepseek-v4-flash": {
          "limit": {
            "context": 1048576,
            "input": 0,
            "output": 65536,
          },
          "options": {
            "provider": {
              "data_collection": "deny",
              "sort": "throughput",
              "allow_fallbacks": true,
              "max_price": {
                "prompt": "0.2",
                "completion": "0.4",
              },
            },
          },
        },
        "google/gemini-3.5-flash": {
          "limit": {
            "context": 1048576,
            "input": 0,
            "output": 65536,
          },
          "options": {
            "provider": {
              "only": ["google-ai-studio"],
              "allow_fallbacks": false,
            },
          },
        },
        "anthropic/claude-fable-5": {
          "limit": {
            "context": 1000000,
            "input": 0,
            "output": 131072,
          },
          "options": {
            "provider": {
              "sort": "throughput",
              "allow_fallbacks": false,
            },
          },
        },
        "anthropic/claude-sonnet-5": {
          "limit": {
            "context": 1000000,
            "input": 0,
            "output": 131072,
          },
          "options": {
            "provider": {
              "sort": "throughput",
              "allow_fallbacks": false,
            },
          },
        },
      },
    },
    "google-ai-studio": {
      "models": {
        "gemini-3.5-flash": {
          "limit": {
            "context": 1048576,
            "input": 0,
            "output": 65536,
          },
        },
      },
    },
    "anthropic": {
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}",
      },
      "models": {
        "claude-fable-5": {
          "limit": {
            "context": 1000000,
            "input": 0,
            "output": 131072,
          },
        },
        "claude-sonnet-5": {
          "limit": {
            "context": 1000000,
            "input": 0,
            "output": 131072,
          },
        },
      },
    },
  },
  "code_edit_display": "expanded",
}
