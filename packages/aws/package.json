{
  "name": "@yai/aws",
  "version": "0.0.14",
  "type": "module",
  "main": "dist/sst.cjs",
  "module": "dist/sst.mjs",
  "types": "dist/sst.d.ts",
  "author": "Yevai Inc.",
  "license": "MIT",
  "keywords": [
    "pulumi",
    "sst",
    "aws",
    "cloud",
    "infrastructure",
    "infra",
    "typescript"
  ],
  "scripts": {
    "build": "rm -rf dist && unbuild"
  },
  "bin": {
    "pulumi-sst": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "homepage": "https://yevai.github.io/npm/modules/_yai_aws.html",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yevai/npm.git",
    "directory": "packages/aws"
  },
  "peerDependencies": {
    "@pulumi/aws": "^7.35.0",
    "@pulumi/pulumi": "^3.250.0",
    "sst": "^4.17.0"
  },
  "peerDependenciesMeta": {
    "@pulumi/pulumi": {
      "optional": true
    },
    "@pulumi/aws": {
      "optional": true
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/sst.d.mts",
        "default": "./dist/sst.mjs"
      },
      "require": {
        "types": "./dist/sst.d.cts",
        "default": "./dist/sst.cjs"
      }
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@pulumi/aws": "^7.35.0",
    "@pulumi/pulumi": "^3.250.0",
    "sst": "^4.17.0",
    "@types/node": "^24",
    "tsx": "4.23.0"
  },
  "dependencies": {
    "commander": "15.0.0",
    "json-to-zod": "1.1.2"
  }
}
