{
  "name": "@yai/aws",
  "version": "0.0.1",
  "type": "module",
  "access": "public",
  "main": "dist/sst.cjs",
  "module": "dist/sst.mjs",
  "types": "dist/sst.d.ts",
  "scripts": {
    "build": "rm -rf dist && unbuild"
  },
  "bin": {
    "pulumi-sst": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yevai/npm.git"
  },
  "peerDependencies": {
    "@pulumi/pulumi": "3.250.0",
    "@pulumi/aws": "7.35.0",
    "sst": "4.17.0"
  },
  "exports": {
    ".": {
      "types": "./dist/sst.d.ts",
      "import": "./dist/sst.mjs",
      "require": "./dist/sst.cjs"
    }
  },
  "engines": {
    "node": "24"
  },
  "devDependencies": {
    "@pulumi/pulumi": "3.250.0",
    "@pulumi/aws": "7.35.0",
    "typescript": "6.0.3",
    "sst": "4.17.0",
    "tsx": "4.23.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24",
    "js-yaml": "^4.0.0",
    "unbuild": "3.6.1"
  }
}
