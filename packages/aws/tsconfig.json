{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "./src",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "strict": true,
    "target": "ES2025",
    "module": "esnext",
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*.ts", "exports/**/*.ts"]
}
